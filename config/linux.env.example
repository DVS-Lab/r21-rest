# Example Linux configuration for R21 resting-state preprocessing.
#
# These defaults are intended for /ZPOOL/data/projects/r21-rest on the Linux
# server. Copy to config/linux.env only if you need local overrides.

PROJECT_NAME="r21-rest"
PROJECT_ROOT="/ZPOOL/data/projects/r21-rest"

BIDS_DIR="/ZPOOL/data/projects/r21-cardgame/bids"

FMRIPREP_IMAGE="/ZPOOL/data/tools/fmriprep-25.2.5.sif"
MRIQC_IMAGE="/ZPOOL/data/tools/mriqc-24.0.2.sif"

TEMPLATEFLOW_DIR="/ZPOOL/data/tools/templateflow"
FS_LICENSE="/ZPOOL/data/tools/licenses/fs_license.txt"

DERIVATIVES_ROOT="${PROJECT_ROOT}/derivatives"
FMRIPREP_OUTPUT_DIR="${DERIVATIVES_ROOT}/fmriprep-25.2.5"
MRIQC_OUTPUT_DIR="${DERIVATIVES_ROOT}/mriqc-24.0.2"
FS_SUBJECTS_DIR="${DERIVATIVES_ROOT}/freesurfer"

WORK_ROOT="/ZPOOL/data/scratch/${USER}"
LOG_ROOT="${DERIVATIVES_ROOT}/logs"
MANIFEST_ROOT="${DERIVATIVES_ROOT}/manifests"
STATUS_ROOT="${DERIVATIVES_ROOT}/status"

TASK_ID="rest"
CONTAINER_RUNTIME="auto"

# fMRIPrep outputs:
# - CIFTI 91k for grayordinates.
# - FSL-compatible MNI152NLin6Asym.
# - No :res-2 modifier, so volumetric BOLD outputs keep native BOLD resolution.
FMRIPREP_OUTPUT_SPACES="fsLR MNI152NLin6Asym"
CIFTI_DENSITY="91k"

# Cautious editable defaults. Compare projected resources with the actual Linux
# host before execution.
FMRIPREP_MAX_JOBS=4
FMRIPREP_NPROCS=8
FMRIPREP_OMP_NTHREADS=4
FMRIPREP_MEM_MB=24000

MRIQC_MAX_JOBS=4
MRIQC_NPROCS=8
MRIQC_OMP_NTHREADS=4
MRIQC_MEM_GB=12

MRIQC_MODALITIES="T1w T2w bold"

# The current source BIDS dataset may not pass the bundled bids-validator cleanly.
# Skip validation here so fMRIPrep can launch; track BIDS issues separately.
FMRIPREP_SKIP_BIDS_VALIDATION=1
FMRIPREP_RESOURCE_MONITOR=1
FMRIPREP_NOTRACK=1

MRIQC_VERBOSE_REPORTS=1
MRIQC_NO_SUBMISSION=1
MRIQC_NOTRACK=1
